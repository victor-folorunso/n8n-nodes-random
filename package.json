{
  "name": "n8n-nodes-random",
  "version": "0.1.2",
  "description": "An n8n community node for random selection. Pick one or more random items from any list in your n8n workflow.",
  "keywords": [
    "n8n-community-node-package",
    "random",
    "pick",
    "sample",
    "shuffle",
    "lottery",
    "selection",
    "list",
    "array"
  ],
  "license": "MIT",
  "author": "Victor Folorunso",
  "homepage": "https://github.com/victor-folorunso/n8n-nodes-random",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victor-folorunso/n8n-nodes-random.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/Random/Random.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": ">=0.23.0",
    "@types/node": "^22.19.17",
    "n8n-workflow": "^2.16.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
